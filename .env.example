# ============================================================
# Biến môi trường cho Trợ lý Giáo vụ Đại Nam
# Sao chép file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# ============================================================

# -- Xác thực Google AI / Gemini --
# Dùng API Key khi chạy local (không cần GCP project)
GOOGLE_API_KEY=your_google_api_key_here

# Hoặc dùng Application Default Credentials khi deploy lên GCP
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-east1

# -- Mô hình Gemini --
# Mặc định dùng gemini-flash-latest (nhanh, phù hợp production)
# GEMINI_MODEL=gemini-flash-latest

# -- Cổng server --
PORT=8080

# -- CORS (danh sách origin được phép, cách nhau bằng dấu phẩy) --
# Để trống = chấp nhận tất cả (chỉ dùng cho dev)
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5000

# -- Lưu trữ artifact (GCS bucket) --
# Tùy chọn: nếu có bucket thì ADK sẽ lưu artifact vào GCS
# LOGS_BUCKET_NAME=ten-bucket-cua-ban

# -- OpenTelemetry / Logging --
# Bật ghi log metadata (KHÔNG ghi nội dung prompt/response)
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT
# COMMIT_SHA=abc123  # dùng để tag phiên bản trong log

# -- Session (để trống = in-memory, stateless) --
# SESSION_SERVICE_URI=  # hoặc redis://... nếu cần persist session

# -- Thông tin deploy --
# COMMIT_SHA=git_commit_sha_here
